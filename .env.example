# open-quake dev-app secrets. Copy this file to `.env` (which is git-ignored) and fill in your values.
# Used by the "HA Schedule" developer app to read your agenda/event input_text helpers from Home Assistant.
# The token stays in the main process — it is never sent to the panel page.

# Your Home Assistant base URL (no trailing slash). Default local port is 8123;
# use your own host/port, or your reverse-proxy URL (e.g. https://ha.example.com).
HA_URL=http://homeassistant.local:8123
HA_TOKEN=paste-your-home-assistant-long-lived-access-token-here
